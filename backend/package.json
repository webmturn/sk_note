{
  "name": "sk-note-backend",
  "version": "1.0.0",
  "description": "Sketchware-Pro Manual Backend - Cloudflare Workers + D1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute sk-note-db --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute sk-note-db --remote --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0",
    "@types/bcryptjs": "^2.4.6"
  }
}
