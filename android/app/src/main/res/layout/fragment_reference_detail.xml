<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="参考详情"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:menu="@menu/menu_reference_detail" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="加载失败"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="重试"
                    style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header card with colored accent -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/detail_section_bg"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Color accent bar -->
                        <View
                            android:id="@+id/headerAccent"
                            android:layout_width="5dp"
                            android:layout_height="match_parent" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <HorizontalScrollView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:scrollbars="none"
                                android:fillViewport="true">

                                <FrameLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:minWidth="0dp">

                                    <com.sknote.app.ui.reference.BlockShapeView
                                        android:id="@+id/blockShapeDetail"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_horizontal"
                                        android:visibility="gone" />

                                    <com.google.android.material.card.MaterialCardView
                                        android:id="@+id/iconCardDetail"
                                        android:layout_width="56dp"
                                        android:layout_height="56dp"
                                        app:cardCornerRadius="14dp"
                                        app:cardElevation="0dp"
                                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                                        android:visibility="gone">

                                        <ImageView
                                            android:id="@+id/ivIconDetail"
                                            android:layout_width="32dp"
                                            android:layout_height="32dp"
                                            android:layout_gravity="center" />
                                    </com.google.android.material.card.MaterialCardView>
                                </FrameLayout>
                            </HorizontalScrollView>

                            <TextView
                                android:id="@+id/tvName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginBottom="8dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_chip_primary"
                                    android:textColor="?attr/colorOnPrimaryContainer"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvCategory"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_chip_secondary"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Description section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="描述"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="6dp"
                    android:drawablePadding="6dp" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurface" />

                <!-- Usage manual section (components/widgets only) -->
                <LinearLayout
                    android:id="@+id/labelManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📖 完整使用手册"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary" />

                    <ImageView
                        android:id="@+id/ivManualArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Widget properties quick-reference -->
                <LinearLayout
                    android:id="@+id/labelWidgetProps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="XML 属性速查"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:drawablePadding="6dp" />

                    <ImageView
                        android:id="@+id/ivPropsArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutWidgetProps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Java code preview section -->
                <LinearLayout
                    android:id="@+id/labelCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Java 代码"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/ivCodeArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/code_bg"
                    app:strokeWidth="0dp"
                    android:visibility="gone">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <TextView
                            android:id="@+id/tvCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="14dp"
                            android:fontFamily="monospace"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:textColor="?attr/colorOnSurface" />
                    </HorizontalScrollView>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/labelParams"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="参数"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/ivParamsArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardParams"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_code_block"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvParameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/labelUsage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="用法"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/ivUsageArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUsage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurface"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/labelExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="示例"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/ivExampleArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_less"
                        android:alpha="0.5" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/code_bg"
                    app:strokeWidth="0dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none">

                            <TextView
                                android:id="@+id/tvExample"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="6dp"
                                android:fontFamily="monospace"
                                android:textSize="13sp"
                                android:lineSpacingMultiplier="1.4"
                                android:textColor="?attr/colorOnSurface" />
                        </HorizontalScrollView>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyCode"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_gravity="end"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="6dp"
                            android:text="复制"
                            android:textSize="11sp"
                            app:icon="@drawable/ic_copy"
                            app:iconSize="14dp"
                            style="@style/Widget.Material3.Button.TextButton" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Event mapping section -->
                <TextView
                    android:id="@+id/labelEventMapping"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutEventMapping"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/labelAssociatedBlocks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="关联积木块"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutAssociatedBlocks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/labelRelated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="相关参考"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutRelatedBlocks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:id="@+id/layoutNavBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="上一个"
            android:textSize="13sp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.TextButton" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="?attr/colorOutlineVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="下一个"
            android:textSize="13sp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textEnd"
            style="@style/Widget.Material3.Button.TextButton" />
    </LinearLayout>
</LinearLayout>
